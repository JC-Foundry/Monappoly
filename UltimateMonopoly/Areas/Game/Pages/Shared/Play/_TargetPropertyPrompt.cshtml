@using JC.Core.Extensions
@using MP.GameEngine.Abstractions
@using MP.GameEngine.Helpers
@using MP.GameEngine.Models.Boards
@using MP.GameEngine.Models.Prompts.PromptTypes
@model TargetPropertyPrompt
@inject IGameEngineFactory EngineFactory
@{
    // The prompt carries only board indexes; resolve names from the game's board for
    // readable labels. gameId is on the route (/player-profile/{gameId}/{userId}) and the
    // cache is already loaded for this render, so this is an in-memory lookup. Falls back
    // to "#index" labels if the board can't be reached.
    Board? board = null;
    var gameId = ViewContext.RouteData.Values["gameId"]?.ToString();
    if (!string.IsNullOrEmpty(gameId))
    {
        try { board = (await EngineFactory.GetAsync(gameId)).Cache.Board; }
        catch { /* no cache — index labels */ }
    }

    var count = Model.Count;
    // Count == 1 → radios (hard single-select, grouped by the shared name); otherwise
    // checkboxes (multi-select up to Count, enforced by the client count-check).
    var inputType = count == 1 ? "radio" : "checkbox";
}
@*
    TARGET-PROPERTY PROMPT — server-rendered fragment. Pick exactly Count properties from
    EligibleBoardIndexes (the engine sets Title/Body to the intent — mortgage / sell / purge / …).
    Each candidate is a btn-check toggle carrying data-target-index; ingame-prompts.js collects
    the checked indexes, validates the count client-side, and submits
    TargetPropertyResponse { selectedBoardIndexes }. Intent-agnostic, so neutral primary styling.
*@
<div class="pp-prompt-card border border-2 border-primary">
    <div class="pp-prompt-head text-bg-primary">
        @(string.IsNullOrEmpty(Model.Title) ? "Choose a property" : Model.Title)
    </div>
    <div class="pp-prompt-body" data-target-count="@count">
        @if (!string.IsNullOrEmpty(Model.Body))
        {
            <p class="mb-2">@Model.Body</p>
        }
        <div class="text-body-secondary small mb-2">
            Select @(count == 1 ? "a property" : $"{count} properties"):
        </div>
        <div class="d-grid gap-2">
            @foreach (var i in Model.EligibleBoardIndexes)
            {
                var slug = PropertySetHelper.ResolveSet(i) is { } set ? set.ToDisplayName().ToSlug() : null;
                var name = board?.GetBoardSpace(i).Name ?? $"Property #{i}";
                var id = $"tp-{Model.PromptId}-{i}";
                <input type="@inputType" name="tp-@Model.PromptId" class="btn-check" id="@id" data-target-index="@i" autocomplete="off" />
                <label class="btn btn-outline-secondary d-flex align-items-center text-start" for="@id">
                    @if (slug is not null)
                    {
                        <span class="pp-set-dot me-2 bg-prop-@slug"></span>
                    }
                    <span class="text-truncate">@name</span>
                </label>
            }
        </div>
        <div class="text-danger small d-none mt-2" data-prompt-error></div>
    </div>
    <div class="pp-prompt-foot">
        <button type="button" class="btn btn-primary w-100" data-prompt-submit>
            <i class="bi bi-check2 me-1"></i> Confirm
        </button>
    </div>
</div>
