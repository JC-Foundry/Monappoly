@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Generate Recovery Codes";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card border-warning">
    <div class="card-body">
        <div class="alert alert-warning mb-3">
            <strong>Store these codes securely.</strong> If you lose your authenticator device and don't have recovery codes, you'll lose access to your account. Generating new codes invalidates any previously generated codes.
        </div>
        <form method="post">
            <button class="btn btn-danger" type="submit">Generate Recovery Codes</button>
        </form>
    </div>
</div>
