<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ultimate Monopoly</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Ultimate Monopoly</a>
            <div class="ms-auto d-flex gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/" class="btn btn-outline-light btn-sm">Back to App</a>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-sm">Login</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">Register</a>
                }
            </div>
        </div>
    </nav>

    <main class="container pb-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
