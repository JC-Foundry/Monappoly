@page
@using UltimateMonopoly.Models.ViewModels.BoardSkins
@model UltimateMonopoly.Pages.Boards.IndexModel
@{
    ViewData["Title"] = "My Boards";

    List<(int Count, string Label, string BadgeClass)> BreakdownBadges(BoardSkinViewModel skin)
    {
        var badges = new List<(int, string, string)>();
        if (skin.PropertiesCustomised > 0) badges.Add((skin.PropertiesCustomised, "Properties", "text-bg-primary"));
        if (skin.StationsCustomised > 0)   badges.Add((skin.StationsCustomised, "Stations", "bg-prop-station text-white"));
        if (skin.UtilitiesCustomised > 0)  badges.Add((skin.UtilitiesCustomised, "Utilities", "bg-prop-utility text-dark"));
        if (skin.CornersCustomised > 0)    badges.Add((skin.CornersCustomised, "Corners", "text-bg-info"));
        if (skin.TaxSpacesCustomised > 0)  badges.Add((skin.TaxSpacesCustomised, "Tax", "text-bg-secondary"));
        return badges;
    }
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h1 class="mb-1">My Boards</h1>
        <p class="text-body-secondary mb-0">Custom board skins you've created.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Edit">New Board Skin</a>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-@(Model.StatusKind ?? "info") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Skins.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <p class="text-body-secondary mb-3">You haven't created any board skins yet.</p>
            <a class="btn btn-primary" asp-page="./Edit">Create your first skin</a>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-end mb-3">
        <div class="btn-group" role="group" aria-label="View toggle">
            <input type="radio" class="btn-check" name="view-toggle" id="view-cards" autocomplete="off" checked />
            <label class="btn btn-outline-secondary btn-sm" for="view-cards">Cards</label>

            <input type="radio" class="btn-check" name="view-toggle" id="view-list" autocomplete="off" />
            <label class="btn btn-outline-secondary btn-sm" for="view-list">List</label>
        </div>
    </div>

    @* Card view *@
    <div data-boards-view="cards">
        <div class="row g-3">
            @foreach (var skin in Model.Skins)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1 text-truncate" title="@skin.Name">@skin.Name</h5>
                            @if (!string.IsNullOrWhiteSpace(skin.Description))
                            {
                                <p class="small text-body-secondary mb-3 text-truncate" title="@skin.Description">@skin.Description</p>
                            }

                            <div class="mb-3">
                                <div class="small text-body-secondary mb-2">
                                    <strong class="text-body">@skin.Spaces.Count</strong>
                                    custom @(skin.Spaces.Count == 1 ? "space" : "spaces")
                                </div>
                                @if (skin.Spaces.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var badge in BreakdownBadges(skin))
                                        {
                                            <span class="badge rounded-pill @badge.BadgeClass">@badge.Count @badge.Label</span>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="mt-auto d-flex gap-2">
                                <a class="btn btn-primary btn-sm flex-grow-1" asp-page="./Edit" asp-route-id="@skin.Id">Edit</a>
                                <a class="btn btn-outline-primary btn-sm" asp-page="./Share" asp-route-id="@skin.Id">Share</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* List view *@
    <div data-boards-view="list" hidden>
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Description</th>
                        <th scope="col" class="text-end">Custom spaces</th>
                        <th scope="col">Breakdown</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var skin in Model.Skins)
                    {
                        <tr>
                            <td class="fw-semibold">@skin.Name</td>
                            <td class="text-body-secondary">
                                @if (!string.IsNullOrWhiteSpace(skin.Description))
                                {
                                    <span>@skin.Description</span>
                                }
                                else
                                {
                                    <span class="text-body-tertiary">—</span>
                                }
                            </td>
                            <td class="text-end">@skin.Spaces.Count</td>
                            <td>
                                @if (skin.Spaces.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var badge in BreakdownBadges(skin))
                                        {
                                            <span class="badge rounded-pill @badge.BadgeClass">@badge.Count @badge.Label</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-body-tertiary">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-primary btn-sm" asp-page="./Edit" asp-route-id="@skin.Id">Edit</a>
                                <a class="btn btn-outline-primary btn-sm" asp-page="./Share" asp-route-id="@skin.Id">Share</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ---------- Board skins shared with me ---------- *@
<h2 class="h4 mt-5 mb-3">Board Skins Shared with Me</h2>
@if (Model.SharedSkins.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-4">
            <p class="text-body-secondary mb-0">No board skins have been shared with you.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var skin in Model.SharedSkins)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1 text-truncate" title="@skin.Name">@skin.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(skin.Description))
                        {
                            <p class="small text-body-secondary mb-3 text-truncate" title="@skin.Description">@skin.Description</p>
                        }

                        <div class="mb-3">
                            <div class="small text-body-secondary mb-2">
                                <strong class="text-body">@skin.Spaces.Count</strong>
                                custom @(skin.Spaces.Count == 1 ? "space" : "spaces")
                            </div>
                            @if (skin.Spaces.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var badge in BreakdownBadges(skin))
                                    {
                                        <span class="badge rounded-pill @badge.BadgeClass">@badge.Count @badge.Label</span>
                                    }
                                </div>
                            }
                        </div>

                        <form method="post" asp-page-handler="RemoveShare" class="mt-auto">
                            <input type="hidden" name="id" value="@skin.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">Remove Shared Board</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="~/scripts/boards.js" asp-append-version="true"></script>
}
