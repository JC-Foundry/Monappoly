@page
@using MP.GameEngine.Helpers.RuleSet
@inject IConfiguration Config
@model UltimateMonopoly.Pages.TermsModel
@{
    ViewData["Title"] = "Terms of Service";
    ViewData["Description"] = $"The terms for using {RuleDictionary.GameName} — a free, independent, unofficial companion app.";

    var webUrl = Config["Routes:WebUrl"] ?? "https://www.monappoly.com/";
    ViewData["Canonical"] = $"{webUrl}Terms";

    var email = Config["Communication:Email:ContactRecipient"] ?? "support@monappoly.com";
    var publisherUrl = Config["Routes:PublisherUrl"] ?? "https://www.jcfoundry.co.uk";
}

